{
  "name": "aws-diagram-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP App that renders AWS architecture diagrams with official AWS icons",
  "scripts": {
    "build:icons:aws": "node scripts/build-icons.mjs",
    "build:icons:azure": "node scripts/build-azure-icons.mjs",
    "build:icons:gcp": "node scripts/build-gcp-icons.mjs",
    "build:icons": "npm run build:icons:aws && npm run build:icons:azure && npm run build:icons:gcp",
    "build:ui": "vite build",
    "build": "npm run build:ui",
    "dev": "npm run build:ui && wrangler dev",
    "deploy": "npm run build:ui && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "build:lambda": "esbuild src/server/lambda.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/lambda/index.js && cp public/index.html dist/lambda/index.html",
    "package:lambda": "cd dist/lambda && zip -r ../../lambda.zip ."
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.15.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^20.14.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0",
    "vite": "^6.3.0",
    "vite-plugin-singlefile": "^2.3.3",
    "wrangler": "^4.0.0"
  }
}
